@app.route('/admin/reset-password', methods=['POST'])
def reset_password():
    user_email = request.form['user_email']
    new_password = request.form['new_password']
    
    # Validation du mot de passe (même critère qu'à l'inscription)
    password_pattern = r'^(?=.*[A-Za-z])(?=.*\d)[A-Za-z\d!@#$%^&*]{8,}$'
    if not re.match(password_pattern, new_password):
        flash("Mot de passe invalide : au moins 8 caractères, alphanumérique, sans \" ou ()", "danger")
        return redirect('/admin')

    # Générer un nouveau sel et hacher le mot de passe
    salt = bcrypt.gensalt()
    new_password_hash = bcrypt.hashpw(new_password.encode('utf-8'), salt)
    
    # Mettre à jour le mot de passe dans la base de données
    conn = sqlite3.connect('./base_donnee.db')
    curseur = conn.cursor()
    curseur.execute("""
        UPDATE USERS 
        SET password_hash = ?, salt = ? 
        WHERE email = ?
    """, (new_password_hash, salt, user_email))
    
    conn.commit()
    conn.close()

    flash("Le mot de passe a été réinitialisé avec succès.", "success")
    return redirect('/admin')



@app.route('/dashboard')
def dashboard():
    if 'user_role' not in session or session['user_role'] not in ['admin', 'client 1', 'client 2']:
        flash("Accès non autorisé", "danger")
        return redirect('/login')
    
    # Logique du tableau de bord en fonction du rôle
    return render_template('dashboard.html')









@app.route('/admin/unblock', methods=['POST'])
def unblock_user():
    email = request.form['email']

    conn = sqlite3.connect('./base_donnee.db')
    curseur = conn.cursor()

    # Supprimer les tentatives de l'utilisateur
    curseur.execute("DELETE FROM login_attempts WHERE user_email = ?", (email,))
    conn.commit()
    conn.close()

    flash(f"L'utilisateur {email} a été débloqué.", "success")
    return redirect('deblocage.html')




if __name__=='__main__':
    
